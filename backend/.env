# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URL=mongodb+srv://admin:skreddy15@frauddetectioncluster.xetemzc.mongodb.net/?appName=frauddetectioncluster
DATABASE_NAME=FraudDetection

# ── Frontend URL (used to build verify links inside emails) ───────────────────
# This is where your React app runs locally during demo
FRONTEND_URL=http://localhost:5173

# ── JWT Secret (must be the same in email_service.py and feedback.py) ─────────
# Used to sign and verify the token embedded in email verify links
# Change this to any long random string for production
FEEDBACK_JWT_SECRET=feedbacksecretkey

# ── SMTP (MailHog — catches emails locally, view at http://localhost:8025) ────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@fraudsystem.com
SMTP_USE_TLS=false